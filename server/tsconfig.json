{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "nodenext",

    "types": ["node"],

    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src"]
}